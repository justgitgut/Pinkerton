{
  "manifest_version": 3,
  "name": "Pinkerton",
  "version": "3.5.0",
  "description": "Track PinaLove.com online user activity. Scans automatically, stores history locally, and displays trends in a private dashboard.",
  "permissions": [
    "scripting",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.pinalove.com/*",
    "https://pinalove.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pinalove.com/*",
        "https://pinalove.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}